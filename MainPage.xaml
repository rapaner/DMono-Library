<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Library.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:MainPageViewModel"
             Title="Моя Библиотека"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">

            <!-- Заголовок -->
            <Label Text="📚 Моя Библиотека"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <!-- Карточка текущей книги -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}"
                    StrokeThickness="0"
                    Padding="20"
                    Margin="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="📖 Текущая книга"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource PrimaryTextColor}" />

                    <Label Text="{Binding CurrentBookTitle}"
                           FontSize="16"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,10,0,0" />

                    <Label Text="{Binding CurrentBookAuthor}"
                           FontSize="14"
                           TextColor="{DynamicResource SecondaryTextColor}" />

                    <ProgressBar Progress="{Binding CurrentBookProgress}"
                                 Margin="0,10,0,0"
                                 ProgressColor="{DynamicResource TertiaryColor}" />

                    <Label Text="{Binding CurrentBookProgressText}"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding CurrentBookPercentage}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource PrimaryColor}"
                           HorizontalOptions="Center"
                           Margin="0,5,0,0" />

                    <Button Text="Просмотр"
                            BackgroundColor="{DynamicResource PrimaryColor}"
                            TextColor="{DynamicResource SecondaryTextColor}"
                            CornerRadius="10"
                            Margin="0,15,0,0"
                            IsVisible="{Binding IsViewCurrentBookVisible}"
                            Command="{Binding ViewCurrentBookCommand}" />
                </StackLayout>
            </Border>

            <!-- Меню действий -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*" ColumnSpacing="15" RowSpacing="15">

                <!-- Просмотр библиотеки -->
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLibraryCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="📚" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Вся библиотека"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Просмотр всех книг"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Добавить книгу -->
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAddBookCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="➕" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Добавить книгу"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Новая книга"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Статистика -->
                <Border Grid.Row="1" Grid.Column="0"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToStatisticsCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="📊" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Статистика"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Мой прогресс"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Выбор книги -->
                <Border Grid.Row="1" Grid.Column="1"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToBookChooseCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="🎲" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Выбор книги"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Рандомный выбор"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Настройки -->
                <Border Grid.Row="2" Grid.Column="0"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToSettingsCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="⚙️" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Настройки"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Конфигурация"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>
            </Grid>
        </StackLayout>
    </ScrollView>
</ContentPage>
