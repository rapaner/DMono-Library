<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage x:Class="Library.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:Library.Views"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:MainPageViewModel"
             Title="Моя Библиотека"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">

            <!-- Заголовок -->
            <Label Text="📚 Моя Библиотека"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <!-- Текущие книги -->
            <Label Text="📖 Текущие книги"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <Border BackgroundColor="{DynamicResource CardBackgroundColor}"
                    StrokeThickness="0"
                    Padding="20"
                    Margin="0"
                    IsVisible="{Binding HasNoCurrentBooks}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <Label Text="Нет активной книги"
                       FontSize="16"
                       TextColor="{DynamicResource SecondaryTextColor}" />
            </Border>

            <StackLayout BindableLayout.ItemsSource="{Binding CurrentBooks}"
                         IsVisible="{Binding HasCurrentBooks}"
                         Spacing="20">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:BookItemViewModel">
                        <Border BackgroundColor="{DynamicResource CardBackgroundColor}"
                                StrokeThickness="0"
                                Padding="20"
                                Margin="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <StackLayout>
                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       TextColor="{DynamicResource SecondaryTextColor}" />

                                <Label Text="{Binding Author, StringFormat='Автор: {0}'}"
                                       FontSize="14"
                                       TextColor="{DynamicResource SecondaryTextColor}" />

                                <ProgressBar Progress="{Binding ProgressPercentage, Converter={StaticResource PercentageConverter}}"
                                             Margin="0,10,0,0"
                                             ProgressColor="{DynamicResource TertiaryColor}" />

                                <Label Text="{Binding ProgressText}"
                                       FontSize="12"
                                       TextColor="{DynamicResource SecondaryTextColor}"
                                       HorizontalOptions="Center" />

                                <Label Text="{Binding ProgressPercentage, StringFormat='{0:F2}%'}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource PrimaryColor}"
                                       HorizontalOptions="Center"
                                       Margin="0,5,0,0" />

                                <Button Text="Просмотр"
                                        BackgroundColor="{DynamicResource PrimaryColor}"
                                        TextColor="{DynamicResource SecondaryTextColor}"
                                        CornerRadius="10"
                                        Margin="0,15,0,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainPageViewModel}}, Path=ViewBookCommand}"
                                        CommandParameter="{Binding}" />
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

            <!-- Меню действий -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*,*" ColumnSpacing="15" RowSpacing="15">

                <!-- Просмотр библиотеки -->
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLibraryCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="📚" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Вся библиотека"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Просмотр всех книг"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Добавить книгу -->
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAddBookCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="➕" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Добавить книгу"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Новая книга"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Статистика -->
                <Border Grid.Row="1" Grid.Column="0"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToStatisticsCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="📊" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Статистика"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Мой прогресс"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Выбор книги -->
                <Border Grid.Row="1" Grid.Column="1"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToBookChooseCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="🎲" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Выбор книги"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Рандомный выбор"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Полки -->
                <Border Grid.Row="2" Grid.Column="0"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToShelvesCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="🗄️" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Полки"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Управление полками"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Авторы -->
                <Border Grid.Row="2" Grid.Column="1"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAuthorsCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="✍️" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Авторы"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Управление авторами"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>

                <!-- Настройки -->
                <Border Grid.Row="3" Grid.Column="0"
                        BackgroundColor="{DynamicResource CardBackgroundColor}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToSettingsCommand}" />
                    </Border.GestureRecognizers>
                    <StackLayout HorizontalOptions="Center">
                        <Label Text="⚙️" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Настройки"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Text="Конфигурация"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                </Border>
            </Grid>
        </StackLayout>
    </ScrollView>
</base:BasePage>
