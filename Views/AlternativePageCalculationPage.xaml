<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Library.Views.AlternativePageCalculationPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:AlternativePageCalculationViewModel"
             Title="Альтернативный расчет страниц"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            
            <!-- Информация о книге -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout>
                    <Label Text="{Binding BookTitleText}" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    <Label Text="{Binding BookAuthorText}" FontSize="16" TextColor="{DynamicResource SecondaryTextColor}" Margin="0,5,0,0" />
                    <Label Text="{Binding TotalPagesText}" FontSize="14" TextColor="{DynamicResource SecondaryTextColor}" Margin="0,5,0,0" />
                </StackLayout>
            </Border>

            <!-- Инструкции -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout>
                    <Label Text="ℹ️ Как использовать" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    <Label Text="Этот функционал позволяет переводить страницы между бумажным и электронным изданиями книги.&#x0a;&#x0a;1. Введите первую страницу основного (бумажного) издания. Последняя страница берется из общего количества страниц книги.&#x0a;&#x0a;2. Введите первую и последнюю страницы альтернативного (электронного) издания.&#x0a;&#x0a;3. После ввода данных вы сможете конвертировать страницы в реальном времени:&#x0a;   - Введите страницу основного издания → справа отобразится эквивалент в альтернативном&#x0a;   - Введите страницу альтернативного издания → справа отобразится эквивалент в основном" 
                           FontSize="14" TextColor="{DynamicResource SecondaryTextColor}" Margin="0,10,0,0" />
                </StackLayout>
            </Border>

            <!-- Настройка диапазонов -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout Spacing="15">
                    <Label Text="📖 Настройка диапазонов страниц" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Label Text="Первая страница основного издания:" FontSize="14" TextColor="{DynamicResource PrimaryTextColor}" Margin="0,10,0,0" />
                    <Entry Text="{Binding MainFirstPageText}" Placeholder="Введите номер первой страницы" Keyboard="Numeric"
                           TextColor="{DynamicResource PrimaryTextColor}" PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                    <Label Text="Последняя страница основного издания берется из общего количества страниц книги" FontSize="12" TextColor="{DynamicResource SecondaryTextColor}" Margin="0,5,0,0" />
                    
                    <Label Text="Первая страница альтернативного издания:" FontSize="14" TextColor="{DynamicResource PrimaryTextColor}" Margin="0,15,0,0" />
                    <Entry Text="{Binding AlternativeFirstPageText}" Placeholder="Введите номер первой страницы" Keyboard="Numeric"
                           TextColor="{DynamicResource PrimaryTextColor}" PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                    
                    <Label Text="Последняя страница альтернативного издания:" FontSize="14" TextColor="{DynamicResource PrimaryTextColor}" Margin="0,15,0,0" />
                    <Entry Text="{Binding AlternativeLastPageText}" Placeholder="Введите номер последней страницы" Keyboard="Numeric"
                           TextColor="{DynamicResource PrimaryTextColor}" PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                </StackLayout>
            </Border>

            <!-- Конвертация -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout Spacing="15">
                    <Label Text="🔄 Конвертация страниц" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Label Text="Страница основного издания:" FontSize="14" TextColor="{DynamicResource PrimaryTextColor}" Margin="0,10,0,0" />
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                        <Entry Grid.Column="0" Text="{Binding MainPageText}" Placeholder="Введите страницу" Keyboard="Numeric"
                               TextColor="{DynamicResource PrimaryTextColor}" PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                        <Label Grid.Column="1" Text="→" FontSize="18" TextColor="{DynamicResource PrimaryTextColor}" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="{Binding AlternativePageResult}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TertiaryColor}" VerticalOptions="Center" />
                    </Grid>
                    
                    <Label Text="Страница альтернативного издания:" FontSize="14" TextColor="{DynamicResource PrimaryTextColor}" Margin="0,15,0,0" />
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                        <Entry Grid.Column="0" Text="{Binding AlternativePageText}" Placeholder="Введите страницу" Keyboard="Numeric"
                               TextColor="{DynamicResource PrimaryTextColor}" PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                        <Label Grid.Column="1" Text="→" FontSize="18" TextColor="{DynamicResource PrimaryTextColor}" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="{Binding MainPageResult}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TertiaryColor}" VerticalOptions="Center" />
                    </Grid>
                </StackLayout>
            </Border>

            <!-- Кнопки -->
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Button Text="✅ Сохранить" BackgroundColor="{DynamicResource PrimaryColor}" TextColor="{DynamicResource SecondaryTextColor}" CornerRadius="10" HorizontalOptions="Fill" Command="{Binding SaveCommand}" />
                <Button Text="❌ Отмена" BackgroundColor="{DynamicResource SecondaryColor}" TextColor="{DynamicResource PrimaryTextColor}" CornerRadius="10" HorizontalOptions="Fill" Command="{Binding CancelCommand}" />
            </StackLayout>

        </StackLayout>
    </ScrollView>

</ContentPage>
