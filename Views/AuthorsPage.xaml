<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage x:Class="Library.Views.AuthorsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:Library.Views"
             xmlns:vm="clr-namespace:Library.ViewModels"
             xmlns:models="clr-namespace:Library.Models"
             x:DataType="vm:AuthorsViewModel"
             Title="Авторы"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <StackLayout Spacing="0">

        <!-- Сортировка -->
        <StackLayout Orientation="Horizontal" 
                     Padding="15,10" 
                     Spacing="10">
            <Label Text="Сортировка:" 
                   FontSize="14" 
                   VerticalOptions="Center" 
                   TextColor="{DynamicResource PrimaryTextColor}" />
            <Picker SelectedIndex="{Binding SelectedSortIndex}"
                    WidthRequest="200">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>По имени</x:String>
                        <x:String>По количеству книг</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </StackLayout>

        <CollectionView ItemsSource="{Binding Authors}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AuthorWithBookCount">
                    <Border BackgroundColor="{DynamicResource PageBackgroundColor}" Padding="15" Margin="0,5" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuthorsViewModel}}, Path=GoToEditAuthorCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <StackLayout Spacing="5">
                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                            <Label Text="{Binding BookCount, StringFormat='Количество книг — {0}'}" FontSize="13" TextColor="{DynamicResource SecondaryTextColor}" />
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>

</base:BasePage>
