<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage x:Class="Library.Views.AddEditShelfPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:Library.Views"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:AddEditShelfViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout Spacing="15">
                    
                    <Label Text="📚 Информация о полке" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <!-- Название -->
                    <StackLayout>
                        <Label Text="Название *" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Entry Text="{Binding Name}"
                               Placeholder="Введите название полки"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                    
                </StackLayout>
            </Border>
            
            <!-- Кнопки действий -->
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Button Text="💾 Сохранить" 
                        BackgroundColor="{DynamicResource PrimaryColor}" 
                        TextColor="{DynamicResource SecondaryTextColor}" 
                        CornerRadius="10" HorizontalOptions="Fill" 
                        Command="{Binding SaveCommand}" />
                <Button Text="❌ Отмена" 
                        BackgroundColor="{DynamicResource SecondaryColor}" 
                        TextColor="{DynamicResource PrimaryTextColor}" 
                        CornerRadius="10" HorizontalOptions="Fill" 
                        Command="{Binding CancelCommand}" />
            </StackLayout>
            
            <!-- Кнопка удаления (только при редактировании) -->
            <Button Text="🗑️ Удалить полку" 
                    BackgroundColor="{DynamicResource ErrorColor}" 
                    TextColor="{DynamicResource PrimaryTextColor}" 
                    CornerRadius="10" 
                    IsVisible="{Binding IsDeleteVisible}"
                    Command="{Binding DeleteCommand}" />
            
            <!-- Книги на полке -->
            <Label Text="📖 Книги на полке" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <Label Text="Нет книг на этой полке"
                   FontSize="14"
                   TextColor="{DynamicResource SecondaryTextColor}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding IsEmpty}" />

            <SearchBar Placeholder="Поиск по названию..."
                       Text="{Binding SearchText}"
                       BackgroundColor="{DynamicResource PageBackgroundColor}"
                       TextColor="{DynamicResource PrimaryTextColor}"
                       PlaceholderColor="{DynamicResource SecondaryTextColor}"
                       IsVisible="{Binding HasBooks}" />

            <StackLayout BindableLayout.ItemsSource="{Binding Books}"
                         Spacing="0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:BookItemViewModel">
                        <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddEditShelfViewModel}}, Path=SelectBookCommand}"
                                    CommandParameter="{Binding}" />
                            </Grid.GestureRecognizers>
                            
                            <Label Grid.Column="0" 
                                   Text="{Binding StatusIcon}" 
                                   FontSize="24" 
                                   VerticalOptions="Center" 
                                   Margin="0,0,15,0" />
                            
                            <StackLayout Grid.Column="1">
                                <Label Text="{Binding Title}" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="{DynamicResource PrimaryTextColor}" />
                                <Label Text="{Binding Author}" 
                                       FontSize="14" 
                                       TextColor="{DynamicResource SecondaryTextColor}" />
                                
                                <StackLayout IsVisible="{Binding IsCurrentlyReading}">
                                    <ProgressBar Progress="{Binding ProgressPercentage, Converter={StaticResource PercentageConverter}}" 
                                                 Margin="0,5,0,0"
                                                 ProgressColor="{DynamicResource TertiaryColor}" />
                                    <Label Text="{Binding ProgressText}" 
                                           FontSize="12" 
                                           TextColor="{DynamicResource SecondaryTextColor}" />
                                </StackLayout>
                            </StackLayout>
                            
                            <StackLayout Grid.Column="2" HorizontalOptions="End">
                                <Label Text="{Binding DateAdded, StringFormat='{0:dd.MM.yyyy}'}" 
                                       FontSize="10" 
                                       TextColor="{DynamicResource SecondaryTextColor}" 
                                       HorizontalOptions="End" />
                            </StackLayout>
                            
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

        </StackLayout>
    </ScrollView>

</base:BasePage>
