<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage x:Class="Library.Views.ShelvesPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:Library.Views"
             xmlns:vm="clr-namespace:Library.ViewModels"
             xmlns:models="clr-namespace:Library.Models"
             x:DataType="vm:ShelvesViewModel"
             Title="Полки"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">

            <Button Text="➕ Новая полка"
                    BackgroundColor="{DynamicResource PrimaryColor}"
                    TextColor="{DynamicResource SecondaryTextColor}"
                    CornerRadius="10"
                    Command="{Binding GoToAddShelfCommand}" />

            <CollectionView ItemsSource="{Binding Shelves}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ShelfWithBookCount">
                        <Border BackgroundColor="{DynamicResource PageBackgroundColor}" Padding="15" Margin="0,5" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShelvesViewModel}}, Path=GoToEditShelfCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <StackLayout Spacing="5">
                                <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                                <Label Text="{Binding BookCount, StringFormat='Количество книг — {0}'}" FontSize="13" TextColor="{DynamicResource SecondaryTextColor}" />
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>
    </ScrollView>

</base:BasePage>
