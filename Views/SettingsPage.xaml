<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Library.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:SettingsViewModel"
             Title="Настройки"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            
            <!-- Информация о приложении -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="ℹ️ О приложении" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Label Text="📚 Моя Библиотека" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" 
                           Margin="0,15,0,5" />
                    
                    <Label Text="{Binding AppVersion}"
                           FontSize="14" 
                           TextColor="{DynamicResource SecondaryTextColor}" />
                    
                    <Label Text="Приложение для ведения личной библиотеки книг. Отслеживайте свой прогресс чтения, ведите заметки и анализируйте статистику." 
                           FontSize="14" 
                           TextColor="{DynamicResource SecondaryTextColor}" 
                           Margin="0,10,0,0" />
                    
                    <Label Text="Авторы" 
                           FontSize="16" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" 
                           Margin="0,20,0,5" />
                    
                    <Label Text="Разработчик - Дмитрий Брагин" 
                           FontSize="14" 
                           TextColor="{DynamicResource SecondaryTextColor}" 
                           Margin="0,5,0,0" />
                    
                    <Label Text="Дизайнер - Тимофей Мухин" 
                           FontSize="14" 
                           TextColor="{DynamicResource SecondaryTextColor}" 
                           Margin="0,5,0,0" />

                    <Label Text="Муза - Мария Брагина ❤️" 
                           FontSize="14" 
                           TextColor="{DynamicResource SecondaryTextColor}" 
                           Margin="0,5,0,0" />
                </StackLayout>
            </Border>

            <!-- Внешний вид -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout Spacing="15">
                    <Label Text="🎨 Внешний вид" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Label Text="Выберите тему приложения" 
                           FontSize="14" 
                           TextColor="{DynamicResource SecondaryTextColor}" />

                    <Picker Title="Выберите тему"
                            SelectedIndex="{Binding SelectedThemeIndex}"
                            TextColor="{DynamicResource PrimaryTextColor}"
                            TitleColor="{DynamicResource SecondaryTextColor}">
                        <Picker.Items>
                            <x:String>🌓 Автоматически (следовать системе)</x:String>
                            <x:String>☀️ Светлая тема</x:String>
                            <x:String>🌙 Темная тема</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="{Binding ThemeDescription}"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,5,0,0" />
                </StackLayout>
            </Border>

            <!-- Резервное копирование -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="☁️ Резервное копирование" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Label Text="Создавайте резервные копии вашей библиотеки на Яндекс Диске" 
                           FontSize="14" 
                           TextColor="{DynamicResource SecondaryTextColor}" 
                           Margin="0,5,0,15" />

                    <Button Text="☁️ Яндекс Диск" 
                            BackgroundColor="{DynamicResource PrimaryColor}" 
                            TextColor="{DynamicResource SecondaryTextColor}" 
                            CornerRadius="10" 
                            Command="{Binding GoToYandexDiskCommand}" />
                </StackLayout>
            </Border>

            <!-- Действия -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="🔧 Действия" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />

                    <Button Text="🗑️ Очистить все данные" 
                            BackgroundColor="{DynamicResource ErrorColor}" 
                            TextColor="{DynamicResource PrimaryTextColor}" 
                            CornerRadius="10" 
                            Margin="0,15,0,0" 
                            Command="{Binding ClearDataCommand}" />
                </StackLayout>
            </Border>

        </StackLayout>
    </ScrollView>

</ContentPage>
