<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage x:Class="Library.Views.EditBookNotesPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:Library.Views"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:EditBookNotesViewModel"
             Title="Заметки"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <Grid RowDefinitions="*,Auto" Padding="20">

        <ScrollView Grid.Row="0">
            <Editor Text="{Binding Notes}"
                    AutoSize="TextChanges"
                    TextColor="{DynamicResource PrimaryTextColor}"
                    PlaceholderColor="{DynamicResource SecondaryTextColor}" />
        </ScrollView>

        <StackLayout Grid.Row="1"
                     Orientation="Horizontal"
                     Spacing="10"
                     Margin="0,20,0,0">
            <Button Text="💾 Сохранить"
                    BackgroundColor="{DynamicResource PrimaryColor}"
                    TextColor="{DynamicResource SecondaryTextColor}"
                    CornerRadius="10"
                    HorizontalOptions="Fill"
                    Command="{Binding SaveCommand}" />
            <Button Text="❌ Отмена"
                    BackgroundColor="{DynamicResource SecondaryColor}"
                    TextColor="{DynamicResource PrimaryTextColor}"
                    CornerRadius="10"
                    HorizontalOptions="Fill"
                    Command="{Binding CancelCommand}" />
        </StackLayout>

    </Grid>

</base:BasePage>
