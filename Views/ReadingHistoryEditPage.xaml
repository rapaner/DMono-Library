<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Library.Views.ReadingHistoryEditPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Редактирование истории чтения"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <Grid RowDefinitions="*,Auto">
        
        <!-- Список записей о чтении -->
        <CollectionView x:Name="HistoryCollectionView"
                       Grid.Row="0"
                       Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{DynamicResource CardBackgroundColor}"
                           Padding="15"
                           Margin="0,5"
                           StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,*,Auto"
                              ColumnSpacing="15"
                              RowSpacing="5">
                            
                            <!-- Дата -->
                            <Label Grid.Column="0"
                                   Text="{Binding Date, StringFormat='{0:dd.MM.yyyy}'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource PrimaryTextColor}"
                                   VerticalOptions="Center" />
                            
                            <!-- Сумма страниц на дату (редактируемое поле) -->
                            <StackLayout Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="5">
                                <Label Text="Сумма:"
                                       FontSize="14"
                                       TextColor="{DynamicResource SecondaryTextColor}"
                                       VerticalOptions="Center" />
                                <Entry Text="{Binding CumulativePages, Mode=TwoWay}"
                                       Keyboard="Numeric"
                                       WidthRequest="100"
                                       MaximumWidthRequest="100"
                                       HorizontalOptions="Start"
                                       TextColor="{DynamicResource PrimaryTextColor}"
                                       Completed="OnCumulativePagesCompleted"
                                       Unfocused="OnCumulativePagesUnfocused" />
                            </StackLayout>
                            
                            <!-- Количество страниц за день (только чтение) -->
                            <StackLayout Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="5">
                                <Label Text="За день:"
                                       FontSize="14"
                                       TextColor="{DynamicResource SecondaryTextColor}"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding DailyPages}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource PrimaryTextColor}"
                                       VerticalOptions="Center" />
                            </StackLayout>
                            
                            <!-- Кнопка удаления -->
                            <Button Grid.Column="3"
                                    Text="🗑️"
                                    BackgroundColor="{DynamicResource ErrorColor}"
                                    TextColor="{DynamicResource PrimaryTextColor}"
                                    CornerRadius="5"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    Padding="0"
                                    Clicked="OnDeleteItemClicked" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <!-- Кнопка сохранения (закреплена внизу) -->
        <Border Grid.Row="1"
                BackgroundColor="{DynamicResource CardBackgroundColor}"
                Padding="10"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0"/>
            </Border.StrokeShape>
            <Button Text="💾 Сохранить"
                    BackgroundColor="{DynamicResource PrimaryColor}"
                    TextColor="{DynamicResource SecondaryTextColor}"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnSaveClicked" />
        </Border>
        
    </Grid>

</ContentPage>

