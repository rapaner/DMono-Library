<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Library.Views.ReadingHistoryEditPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:ReadingHistoryEditViewModel"
             Title="Редактирование истории чтения"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <Grid RowDefinitions="*,Auto">
        
        <CollectionView Grid.Row="0"
                         ItemsSource="{Binding Items}"
                         Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ReadingHistoryItemViewModel">
                    <Border BackgroundColor="{DynamicResource CardBackgroundColor}"
                           Padding="15" Margin="0,5" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15">
                            
                            <Grid Grid.Column="0" RowDefinitions="Auto,Auto" RowSpacing="5">
                                <Label Grid.Row="0"
                                       Text="{Binding Date, StringFormat='{0:dd.MM.yyyy}'}"
                                       FontSize="16" FontAttributes="Bold"
                                       TextColor="{DynamicResource PrimaryTextColor}" />
                                
                                <StackLayout Grid.Row="1" Orientation="Horizontal" Spacing="15">
                                    <StackLayout Orientation="Horizontal" Spacing="5">
                                        <Label Text="Сумма:" FontSize="14" TextColor="{DynamicResource SecondaryTextColor}" VerticalOptions="Center" />
                                        <Entry Text="{Binding CumulativePages, Mode=TwoWay}"
                                               Keyboard="Numeric" WidthRequest="100" MaximumWidthRequest="100"
                                               HorizontalOptions="Start"
                                               TextColor="{DynamicResource PrimaryTextColor}"
                                               Completed="OnCumulativePagesCompleted"
                                               Unfocused="OnCumulativePagesUnfocused" />
                                    </StackLayout>
                                    <StackLayout Orientation="Horizontal" Spacing="5">
                                        <Label Text="За день:" FontSize="14" TextColor="{DynamicResource SecondaryTextColor}" VerticalOptions="Center" />
                                        <Label Text="{Binding DailyPages}" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" VerticalOptions="Center" />
                                    </StackLayout>
                                </StackLayout>
                            </Grid>
                            
                            <Button Grid.Column="1" Text="🗑️"
                                    BackgroundColor="{DynamicResource ErrorColor}"
                                    TextColor="{DynamicResource PrimaryTextColor}"
                                    CornerRadius="5" WidthRequest="50" Padding="0" VerticalOptions="Fill"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReadingHistoryEditViewModel}}, Path=DeleteItemCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Border Grid.Row="1" BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="10" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0"/></Border.StrokeShape>
            <Button Text="💾 Сохранить"
                    BackgroundColor="{DynamicResource PrimaryColor}"
                    TextColor="{DynamicResource SecondaryTextColor}"
                    CornerRadius="10" HeightRequest="50"
                    Command="{Binding SaveCommand}" />
        </Border>
        
    </Grid>

</ContentPage>
