<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Library.Views.BookDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Library.ViewModels"
             x:DataType="vm:BookDetailViewModel"
             Title="Детали книги"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            
            <!-- Заголовок книги -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="{Binding BookTitle}" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    <Label Text="{Binding BookAuthor}" 
                           FontSize="18" 
                           TextColor="{DynamicResource SecondaryTextColor}" 
                           Margin="0,5,0,0" />
                </StackLayout>
            </Border>

            <!-- Прогресс чтения -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="📊 Прогресс чтения" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <ProgressBar Progress="{Binding Progress}" 
                                 Margin="0,15,0,10"
                                 ProgressColor="{DynamicResource TertiaryColor}" />
                    
                    <Label Text="{Binding ProgressText}" 
                           FontSize="16" 
                           TextColor="{DynamicResource PrimaryTextColor}" 
                           HorizontalOptions="Center" />
                    
                    <Label Text="{Binding ProgressPercentage}" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="{DynamicResource PrimaryTextColor}" 
                           HorizontalOptions="Center"
                           Margin="0,10,0,0" />
                    
                    <Label Text="{Binding EstimatedFinishDate}"
                           FontSize="14"
                           TextColor="{DynamicResource PrimaryTextColor}"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"
                           IsVisible="{Binding IsEstimatedFinishDateVisible}" />
                    
                    <Button Text="📝 Обновить прогресс" 
                            BackgroundColor="{DynamicResource PrimaryColor}" 
                            TextColor="{DynamicResource SecondaryTextColor}" 
                            CornerRadius="10" 
                            Margin="0,15,0,0" 
                            IsVisible="{Binding IsUpdateProgressVisible}"
                            Command="{Binding UpdateProgressCommand}" />
                    
                    <Button Text="⏰ График чтения по часам" 
                            BackgroundColor="{DynamicResource TertiaryColor}" 
                            TextColor="{DynamicResource PrimaryTextColor}" 
                            CornerRadius="10" 
                            Margin="0,10,0,0" 
                            IsVisible="{Binding IsReadingScheduleVisible}"
                            Command="{Binding GoToReadingScheduleCommand}" />
                    
                    <Button Text="🔄 Альтернативный расчет страниц" 
                            BackgroundColor="{DynamicResource SecondaryColor}" 
                            TextColor="{DynamicResource PrimaryTextColor}" 
                            CornerRadius="10" 
                            Margin="0,10,0,0" 
                            IsVisible="{Binding IsAlternativeCalculationVisible}"
                            Command="{Binding GoToAlternativeCalculationCommand}" />
                </StackLayout>
            </Border>

            <!-- График чтения по дням -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0"
                   IsVisible="{Binding IsChartVisible}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="📈 График чтения" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Label Text="{Binding ChartDescription}"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,5,0,5" />
                    
                    <Label Text="{Binding AverageDailyText}"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,0,0,10" />
                    
                    <ScrollView Orientation="Horizontal" 
                                HorizontalScrollBarVisibility="Always"
                                Margin="0,10,0,0">
                        <ContentView>
                            <ContentView.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenReadingHistoryCommand}" />
                            </ContentView.GestureRecognizers>
                            <GraphicsView x:Name="ReadingChartView"
                                          HeightRequest="250"
                                          WidthRequest="{Binding ChartWidth}"
                                          Drawable="{Binding ChartDrawable}"
                                          BackgroundColor="Transparent"
                                          InputTransparent="True" />
                        </ContentView>
                    </ScrollView>
                    
                    <Label Text="Нажмите на график, чтобы отредактировать историю чтения по дням (доступно только для книг в статусе &quot;Читаю сейчас&quot;)"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,10,0,0"
                           IsVisible="{Binding IsChartHintVisible}" />
                </StackLayout>
            </Border>

            <!-- Информация о книге -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="📖 Информация о книге" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,*,*,*,*,*,*" 
                          ColumnSpacing="10" RowSpacing="10" Margin="0,15,0,0">
                        
                        <Label Grid.Row="0" Grid.Column="0" 
                               Text="Всего страниц:" FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label Grid.Row="0" Grid.Column="1" 
                               Text="{Binding TotalPages}" FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label Grid.Row="1" Grid.Column="0" 
                               Text="Статус:" FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label Grid.Row="1" Grid.Column="1" 
                               Text="{Binding StatusText}" FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label Grid.Row="2" Grid.Column="0" 
                               Text="Дата добавления:" FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label Grid.Row="2" Grid.Column="1" 
                               Text="{Binding DateAdded}" FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label Grid.Row="3" Grid.Column="0"
                               Text="Дата начала чтения:" FontSize="14"
                               TextColor="{DynamicResource SecondaryTextColor}"
                               IsVisible="{Binding IsDateStartedVisible}" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="{Binding DateStarted}" FontSize="14"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               IsVisible="{Binding IsDateStartedVisible}" />

                        <Label Grid.Row="4" Grid.Column="0" 
                               Text="Дата завершения:" FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}"
                               IsVisible="{Binding IsDateFinishedVisible}" />
                        <Label Grid.Row="4" Grid.Column="1"
                               Text="{Binding DateFinished}" FontSize="14"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               IsVisible="{Binding IsDateFinishedVisible}" />
                        
                        <Label Grid.Row="5" Grid.Column="0" 
                               Text="Цикл:" FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label Grid.Row="5" Grid.Column="1" 
                               Text="{Binding SeriesTitle}" FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label Grid.Row="6" Grid.Column="0" 
                               Text="Номер в цикле:" FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label Grid.Row="6" Grid.Column="1" 
                               Text="{Binding SeriesNumber}" FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                    </Grid>
                </StackLayout>
            </Border>

            <!-- Действия -->
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Button Text="✏️ Редактировать" 
                        BackgroundColor="{DynamicResource SecondaryColor}" 
                        TextColor="{DynamicResource PrimaryTextColor}" 
                        CornerRadius="10" 
                        HorizontalOptions="Fill" 
                        Command="{Binding EditBookCommand}" />
                <Button Text="🗑️ Удалить" 
                        BackgroundColor="{DynamicResource ErrorColor}" 
                        TextColor="{DynamicResource PrimaryTextColor}" 
                        CornerRadius="10" 
                        HorizontalOptions="Fill" 
                        Command="{Binding DeleteBookCommand}" />
            </StackLayout>

        </StackLayout>
    </ScrollView>

</ContentPage>
