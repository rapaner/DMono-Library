<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Library.Views.BookDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Детали книги"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            
            <!-- Заголовок книги -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label x:Name="BookTitle" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    <Label x:Name="BookAuthor" 
                           FontSize="18" 
                           TextColor="{DynamicResource SecondaryTextColor}" 
                           Margin="0,5,0,0" />
                </StackLayout>
            </Border>

            <!-- Прогресс чтения -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="📊 Прогресс чтения" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <ProgressBar x:Name="ProgressBar" 
                                 Progress="0" 
                                 Margin="0,15,0,10"
                                 ProgressColor="{DynamicResource TertiaryColor}" />
                    
                    <Label x:Name="ProgressText" 
                           FontSize="16" 
                           TextColor="{DynamicResource PrimaryTextColor}" 
                           HorizontalOptions="Center" />
                    
                    <Label x:Name="ProgressPercentage" 
                           Text="" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="{DynamicResource PrimaryTextColor}" 
                           HorizontalOptions="Center"
                           Margin="0,10,0,0" />
                    
                    <Label x:Name="EstimatedFinishDateLabel"
                           Text=""
                           FontSize="14"
                           TextColor="{DynamicResource PrimaryTextColor}"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"
                           IsVisible="False" />
                    
                    <!-- Кнопка обновления прогресса -->
                    <Button x:Name="UpdateProgressButton"
                            Text="📝 Обновить прогресс" 
                            BackgroundColor="{DynamicResource PrimaryColor}" 
                            TextColor="{DynamicResource SecondaryTextColor}" 
                            CornerRadius="10" 
                            Margin="0,15,0,0" 
                            Clicked="OnUpdateProgressClicked" />
                    
                    <!-- Кнопка графика чтения по часам -->
                    <Button x:Name="ReadingScheduleButton"
                            Text="⏰ График чтения по часам" 
                            BackgroundColor="{DynamicResource TertiaryColor}" 
                            TextColor="{DynamicResource PrimaryTextColor}" 
                            CornerRadius="10" 
                            Margin="0,10,0,0" 
                            Clicked="OnReadingScheduleClicked" />
                    
                    <!-- Кнопка альтернативного расчета страниц -->
                    <Button x:Name="AlternativeCalculationButton"
                            Text="🔄 Альтернативный расчет страниц" 
                            BackgroundColor="{DynamicResource SecondaryColor}" 
                            TextColor="{DynamicResource PrimaryTextColor}" 
                            CornerRadius="10" 
                            Margin="0,10,0,0" 
                            Clicked="OnAlternativePageCalculationClicked" />
                </StackLayout>
            </Border>

            <!-- График чтения по дням -->
            <Border x:Name="ChartBorder"
                   BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0"
                   IsVisible="True">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="📈 График чтения" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Label x:Name="ChartDescriptionLabel"
                           Text="Страниц прочитано по дням"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,5,0,5" />
                    
                    <Label x:Name="AverageDailyLabel"
                           Text="Среднее количество в день - 0.00"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,0,0,10" />
                    
                    <ScrollView Orientation="Horizontal" 
                                HorizontalScrollBarVisibility="Always"
                                Margin="0,10,0,0">
                        <GraphicsView x:Name="ReadingChartView"
                                      HeightRequest="250"
                                      WidthRequest="400"
                                      BackgroundColor="Transparent">
                            <GraphicsView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnReadingChartTapped" />
                            </GraphicsView.GestureRecognizers>
                        </GraphicsView>
                    </ScrollView>
                    
                    <Label x:Name="ChartHintLabel"
                           Text="Нажмите на график, чтобы отредактировать историю чтения по дням (доступно только для книг в статусе &quot;Читаю сейчас&quot;)"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryTextColor}"
                           Margin="0,10,0,0"
                           IsVisible="False" />
                </StackLayout>
            </Border>

            <!-- Информация о книге -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" 
                   Padding="20" 
                   StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <StackLayout>
                    <Label Text="📖 Информация о книге" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,*,*,*,*,*,*" 
                          ColumnSpacing="10" RowSpacing="10" Margin="0,15,0,0">
                        
                        <Label Grid.Row="0" Grid.Column="0" 
                               Text="Всего страниц:" 
                               FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label x:Name="TotalPagesLabel" 
                               Grid.Row="0" Grid.Column="1" 
                               FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label Grid.Row="1" Grid.Column="0" 
                               Text="Статус:" 
                               FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label x:Name="StatusLabel" 
                               Grid.Row="1" Grid.Column="1" 
                               FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label Grid.Row="2" Grid.Column="0" 
                               Text="Дата добавления:" 
                               FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label x:Name="DateAddedLabel" 
                               Grid.Row="2" Grid.Column="1" 
                               FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label x:Name="DateStartedCaptionLabel"
                               Grid.Row="3" Grid.Column="0"
                               Text="Дата начала чтения:"
                               FontSize="14"
                               TextColor="{DynamicResource SecondaryTextColor}"
                               IsVisible="False" />
                        <Label x:Name="DateStartedLabel"
                               Grid.Row="3" Grid.Column="1"
                               FontSize="14"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               IsVisible="False" />

                        <Label x:Name="DateFinishedCaptionLabel"
                               Grid.Row="4" Grid.Column="0" 
                               Text="Дата завершения:" 
                               FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}"
                               IsVisible="False" />
                        <Label x:Name="DateFinishedLabel"
                               Grid.Row="4" Grid.Column="1"
                               FontSize="14"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               IsVisible="False" />
                        
                        <Label Grid.Row="5" Grid.Column="0" 
                               Text="Цикл:" 
                               FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label x:Name="SeriesTitleLabel" 
                               Grid.Row="5" Grid.Column="1" 
                               FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                        
                        <Label Grid.Row="6" Grid.Column="0" 
                               Text="Номер в цикле:" 
                               FontSize="14" 
                               TextColor="{DynamicResource SecondaryTextColor}" />
                        <Label x:Name="SeriesNumberLabel" 
                               Grid.Row="6" Grid.Column="1" 
                               FontSize="14" 
                               TextColor="{DynamicResource PrimaryTextColor}" />
                    </Grid>
                </StackLayout>
            </Border>

            <!-- Действия -->
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Button Text="✏️ Редактировать" 
                        BackgroundColor="{DynamicResource SecondaryColor}" 
                        TextColor="{DynamicResource PrimaryTextColor}" 
                        CornerRadius="10" 
                        HorizontalOptions="Fill" 
                        Clicked="OnEditBookClicked" />
                <Button Text="🗑️ Удалить" 
                        BackgroundColor="{DynamicResource ErrorColor}" 
                        TextColor="{DynamicResource PrimaryTextColor}" 
                        CornerRadius="10" 
                        HorizontalOptions="Fill" 
                        Clicked="OnDeleteBookClicked" />
            </StackLayout>

        </StackLayout>
    </ScrollView>

</ContentPage>
