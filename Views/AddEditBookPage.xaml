<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage x:Class="Library.Views.AddEditBookPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:Library.Views"
             xmlns:vm="clr-namespace:Library.ViewModels"
             xmlns:models="clr-namespace:Library.Core.Models;assembly=Library.Core"
             x:DataType="vm:AddEditBookViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout Spacing="15">
                    
                    <Label Text="📚 Информация о книге" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    
                    <!-- Название -->
                    <StackLayout>
                        <Label Text="Название *" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Entry Text="{Binding Title}"
                               Placeholder="Введите название книги"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                    
                    <!-- Авторы -->
                    <StackLayout>
                        <Label Text="Авторы *" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="5">
                            <Picker Grid.Column="0"
                                    Title="Выберите автора"
                                    ItemsSource="{Binding AuthorNames}"
                                    SelectedIndex="{Binding AuthorPickerIndex}"
                                    TextColor="{DynamicResource PrimaryTextColor}"
                                    TitleColor="{DynamicResource SecondaryTextColor}" />
                            <Button Text="+" Grid.Column="1"
                                    BackgroundColor="{DynamicResource PrimaryColor}" 
                                    TextColor="{DynamicResource SecondaryTextColor}" 
                                    WidthRequest="50"
                                    Command="{Binding AddAuthorCommand}" />
                            <Button Text="Новый" Grid.Column="2"
                                    BackgroundColor="{DynamicResource SecondaryColor}" 
                                    TextColor="{DynamicResource SecondaryTextColor}" 
                                    WidthRequest="80"
                                    Command="{Binding NewAuthorCommand}" />
                        </Grid>
                        
                        <CollectionView ItemsSource="{Binding SelectedAuthors}" Margin="0,10,0,0">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Author">
                                    <Grid Padding="5" ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Name}" Grid.Column="0" VerticalOptions="Center" TextColor="{DynamicResource PrimaryTextColor}" />
                                        <Button Text="✕" Grid.Column="1"
                                                BackgroundColor="{DynamicResource ErrorColor}" 
                                                TextColor="{DynamicResource PrimaryTextColor}" 
                                                WidthRequest="40" HeightRequest="40" CornerRadius="20"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddEditBookViewModel}}, Path=RemoveAuthorCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                    
                    <!-- Цикл -->
                    <StackLayout>
                        <Label Text="Название цикла" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Entry Text="{Binding SeriesTitle}"
                               Placeholder="Введите название цикла (необязательно)"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                    
                    <!-- Номер в цикле -->
                    <StackLayout>
                        <Label Text="Номер в цикле" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Entry Text="{Binding SeriesNumberText}"
                               Placeholder="Номер книги в цикле (необязательно)" 
                               Keyboard="Numeric"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                    
                    <!-- Страницы -->
                    <StackLayout>
                        <Label Text="Общее количество страниц *" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Entry Text="{Binding TotalPagesText}"
                               Placeholder="Введите количество страниц" 
                               Keyboard="Numeric"
                               TextColor="{DynamicResource PrimaryTextColor}"
                               PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                    </StackLayout>
                    
                    <!-- Статус -->
                    <StackLayout>
                        <Label Text="Статус" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Picker SelectedIndex="{Binding StatusPickerIndex}"
                                TextColor="{DynamicResource PrimaryTextColor}"
                                TitleColor="{DynamicResource SecondaryTextColor}">
                            <Picker.Items>
                                <x:String>В планах</x:String>
                                <x:String>Читаю сейчас</x:String>
                                <x:String>Прочитано</x:String>
                            </Picker.Items>
                        </Picker>
                    </StackLayout>
                    
                </StackLayout>
            </Border>
            
            <!-- Кнопки действий -->
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Button Text="💾 Сохранить" 
                        BackgroundColor="{DynamicResource PrimaryColor}" 
                        TextColor="{DynamicResource SecondaryTextColor}" 
                        CornerRadius="10" HorizontalOptions="Fill" 
                        Command="{Binding SaveCommand}" />
                <Button Text="❌ Отмена" 
                        BackgroundColor="{DynamicResource SecondaryColor}" 
                        TextColor="{DynamicResource PrimaryTextColor}" 
                        CornerRadius="10" HorizontalOptions="Fill" 
                        Command="{Binding CancelCommand}" />
            </StackLayout>
            
        </StackLayout>
    </ScrollView>

</base:BasePage>
