<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage x:Class="Library.Views.ReadingSchedulePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:Library.Views"
             xmlns:vm="clr-namespace:Library.ViewModels"
             xmlns:models="clr-namespace:Library.Models"
             x:DataType="vm:ReadingScheduleViewModel"
             Title="График чтения"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            
            <!-- Информация о книге -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout>
                    <Label Text="{Binding BookTitleText}" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    <Label Text="{Binding BookAuthorText}" FontSize="16" TextColor="{DynamicResource SecondaryTextColor}" Margin="0,5,0,10" />
                    <Label Text="{Binding ProgressText}" FontSize="16" TextColor="{DynamicResource PrimaryTextColor}" />
                </StackLayout>
            </Border>

            <!-- Настройки -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout Spacing="15">
                    <Label Text="⚙️ Настройки расписания" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" />
                    <StackLayout>
                        <Label Text="Целевая дата окончания" FontSize="14" TextColor="{DynamicResource SecondaryTextColor}" />
                        <DatePicker Date="{Binding FinishDate}"
                                    MinimumDate="{Binding MinimumDate}"
                                    TextColor="{DynamicResource PrimaryTextColor}"
                                    Margin="0,5,0,0" />
                    </StackLayout>
                    <StackLayout>
                        <Label Text="Часы чтения" FontSize="14" TextColor="{DynamicResource SecondaryTextColor}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,5,0,0">
                            <StackLayout Grid.Column="0">
                                <Label Text="Начало (час)" FontSize="12" TextColor="{DynamicResource SecondaryTextColor}" />
                                <Entry Text="{Binding StartHourText}" Keyboard="Numeric" Placeholder="6"
                                       TextColor="{DynamicResource PrimaryTextColor}" PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                            </StackLayout>
                            <StackLayout Grid.Column="1">
                                <Label Text="Окончание (час)" FontSize="12" TextColor="{DynamicResource SecondaryTextColor}" />
                                <Entry Text="{Binding EndHourText}" Keyboard="Numeric" Placeholder="23"
                                       TextColor="{DynamicResource PrimaryTextColor}" PlaceholderColor="{DynamicResource SecondaryTextColor}" />
                            </StackLayout>
                        </Grid>
                        <Label Text="Оставьте пустым для использования глобальных настроек" FontSize="12" TextColor="{DynamicResource SecondaryTextColor}" Margin="0,5,0,0" />
                    </StackLayout>
                    <Button Text="📊 Рассчитать график" 
                            BackgroundColor="{DynamicResource PrimaryColor}" TextColor="{DynamicResource SecondaryTextColor}" 
                            CornerRadius="10" Margin="0,10,0,0"
                            Command="{Binding CalculateCommand}" />
                </StackLayout>
            </Border>

            <!-- График -->
            <Border BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="20" StrokeThickness="0" IsVisible="{Binding IsScheduleVisible}">
                <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                <StackLayout>
                    <Label Text="📅 Почасовой график" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource PrimaryTextColor}" Margin="0,0,0,15" />
                    <Label Text="{Binding ScheduleSummary}" FontSize="14" TextColor="{DynamicResource PrimaryTextColor}" Margin="0,0,0,15" />
                    <CollectionView ItemsSource="{Binding ScheduleRecords}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReadByHourRecord">
                                <Border BackgroundColor="{DynamicResource InputBackgroundColor}" Padding="15" Margin="0,5" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="{Binding TimeStamp}" FontSize="14" TextColor="{DynamicResource PrimaryTextColor}" VerticalOptions="Center" />
                                        <Label Grid.Column="1" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TertiaryColor}" VerticalOptions="Center">
                                            <Label.Text>
                                                <Binding Path="Pages" StringFormat="{}{0:F0} стр." />
                                            </Label.Text>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{DynamicResource PrimaryColor}" HeightRequest="50" />
        </StackLayout>
    </ScrollView>
</base:BasePage>
